    with stage_log("silver", "Building Spark session"):
        spark = pipeline["build_spark"]()
    try:
        with stage_log("silver", "Running Bronze to Silver transformations"):
            silver_outputs = pipeline["run_bronze_to_silver"](settings, spark)
