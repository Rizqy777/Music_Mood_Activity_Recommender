        pretty = dict(zip(ACTIVITY_PROFILE_COLS, values.clip(0.0, 1.0).round(3).tolist()))
        print(example, label, pretty)


def expand_phrase(phrase: str) -> list[str]:
    normalized = normalize_text(phrase)
