# Dataset and local lake paths are resolved with pathlib and can be absolute or relative.
DATASETS_DIR=datasets
LOCAL_LAKE_DIR=data_lake

# Keep this limited during local tests. Leave empty to stream all rows.
MAX_ROWS_PER_DATASET=1000
PRODUCER_BATCH_SIZE=500
CONSUMER_TIMEOUT_SECONDS=30

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=music-recommender-pipeline
KAFKA_MOOD_TOPIC=mood_dataset_events
KAFKA_TRACKS_TOPIC=tracks_dataset_events

# Set USE_S3=false for purely local tests. Keep true when AWS credentials/bucket are valid.
USE_S3=true
AWS_S3_ENDPOINT_URL=

MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=music_recommender

RDS_DSN=dbname=music_recommender user=postgres password=postgres host=localhost port=5432
